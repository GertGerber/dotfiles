# Starship Prompt Configuration
# https://starship.rs/config/

add_newline = false

[character]
success_symbol = "[➜](bold green)"
error_symbol = "[✗](bold red)"

[directory]
truncation_length = 3
truncate_to_repo = false
style = "blue bold"

[git_branch]
symbol = " "
style = "purple bold"

[git_status]
conflicted = "⚔️ "
ahead = "⇡${count}"
behind = "⇣${count}"
staged = "+${count}"
deleted = "✖ ${count}"
modified = "~${count}"
untracked = "?${count}"
style = "bold yellow"

[time]
disabled = false
format = "🕒 [$time]($style) "
style = "bold cyan"

[cmd_duration]
min_time = 2000
format = "⏱️ [$duration]($style) "
style = "bold white"
