# ====================================================================
# TechDufus Dotfiles Configuration Example
# ====================================================================
#
# Copy this file to `all.yml` and customize your setup:
#   cp group_vars/all.yml.example group_vars/all.yml
#   nvim group_vars/all.yml
#
# Then run the bootstrap script:
#   dotfiles
#
# ====================================================================

# --------------------------------------------------------------------
# ROLE ACTIVATION
# --------------------------------------------------------------------
# Use this section to select which roles to install.
# Uncomment a role to enable it. Comment out or remove to skip.
# Roles are modular and support install/uninstall via the 'dotfiles' alias.
default_roles:
  # === Core System Tools (Recommended) ===
  - system        # Essential system configurations and base tools
  - fonts         # Developer-friendly fonts (Nerd Fonts)

  # === Development Core ===
  - git           # Git is already installed by bootstrap
                  # Role will configure git_user_name/email and SSH keys
  - neovim        # Will install Neovim if missing
  - tmux          # Will install tmux if missing

  # === Shell Environment ===
  - zsh           # Will install zsh if missing
  - starship      # Will install starship prompt
  - fzf           # Will install fuzzy finder

  # === File Management ===
  - bat           # Will install bat if missing
  - lsd           # Will install lsd
  - zoxide        # Will install zoxide

  # === Development Languages ===
  - python        # Python3/pip3 already installed by bootstrap
                  # Role installs additional Python packages: virtualenv, pipenv, etc.
  - nvm           # Will install Node Version Manager
  - npm           # Will install Node Package Manager
  - go            # Will install Go language
  # - rust        # Optional
  # - ruby        # Optional
  # - lua         # Optional

  # === DevOps & Cloud Tools ===
  # - docker      # Will install Docker if enabled
  # - podman      # Alternative container platform
  # - terraform   # Infrastructure as Code
  # - terragrunt  # Terraform wrapper
  # - helm        # Kubernetes package manager
  # - k8s         # Kubernetes CLI tools
  # - k9s         # Kubernetes cluster manager

  # === GitHub Integration ===
  - gh            # Will install GitHub CLI
  - lazygit       # Will install terminal git UI

  # === System Monitoring ===
  # - btop        # Optional
  # - neofetch    # Optional
  # - ncdu        # Optional

  # === Terminal Emulators ===
  # - kitty       # Optional
  # - warp        # Optional

  # === Productivity Tools ===
  # - obsidian
  # - raycast
  # - taskfile
  # - tldr

  # === Communication & Media ===
  # - discord
  # - spotify

  # === Network & Remote Access ===
  # - ssh
  # - sshfs
  # - tmate

  # === macOS Specific ===
  # - aldente

  # === Linux Specific ===
  # - flatpak
  # - nala

  # === Browser Tools ===
  # - brave

  # === Cloud & Infrastructure CLIs ===
  # - aws
  # - azure
  # - nomad

  # === Security & Authentication ===
  # - 1password

# --------------------------------------------------------------------
# USER CONFIGURATION
# --------------------------------------------------------------------
git_user_name: "Your Full Name"
git_user_email: "your.email@example.com"

# --------------------------------------------------------------------
# PER-ROLE CUSTOMIZATION
# --------------------------------------------------------------------

# Python role
python:
  packages:
    - virtualenv
    - pipenv
    - black
    - flake8
    - pytest

# Node.js role
node:
  default_version: "18"
  packages:
    - yarn
    - typescript
    - eslint
    - prettier

# Go role
go:
  packages:
    - package: github.com/go-task/task/v3/cmd/task@latest
      cmd: task
    - package: github.com/stern/stern@latest
      cmd: stern
    - package: github.com/golangci/golangci-lint/cmd/golangci-lint@latest
      cmd: golangci-lint

# Kubernetes role
k8s:
  version: "v1.28"

# Helm role
helm:
  repos:
    - name: traefik
      url: https://helm.traefik.io/traefik
    - name: prometheus
      url: https://prometheus-community.github.io/helm-charts

# 1Password integration
op:
  git:
    user:
      email: "op://Personal/GitHub/email"
      allowed_signers: "op://Personal/GitHub SSH/allowed_signers"
  ssh:
    github:
      personal:
        - name: id_ed25519
          vault_path: "op://Personal/GitHub SSH"

# --------------------------------------------------------------------
# INSTRUCTIONS
# --------------------------------------------------------------------
# 1. Copy this file to 'all.yml' and fill in your personal info
# 2. Enable only the roles you need (uncomment or remove others)
#    * Roles already installed by bootstrap: git, python3, pip3, ansible
#    * Remaining roles will install new software as needed
# 3. Run the bootstrap script:
#      dotfiles
# 4. To uninstall a role, comment it out in 'all.yml' and run:
#      dotfiles --uninstall
# 5. Rerun anytime to apply changes or update roles

# --------------------------------------------------------------------
# TROUBLESHOOTING
# --------------------------------------------------------------------
# - "Role not found": check spelling in default_roles
# - "1Password auth failed": run `op signin`
# - "Permission denied": ensure sudo access
# - "Ansible not found": bootstrap script should install it
