RED="$CAT_RED"
GREEN="$CAT_GREEN"
YELLOW="$CAT_YELLOW"
BLUE="$CAT_BLUE"
PURPLE="$CAT_MAUVE"
CYAN="$CAT_TEAL"
WHITE="$CAT_TEXT"
SEA="$CAT_SAPPHIRE"
NC="\e[0m"

# -----------------------------
# Emojis
# -----------------------------
CHECK_MARK="${GREEN}✔${NC}"
X_MARK="${RED}✖${NC}"
PIN="${RED}📌${NC}"
CLOCK="${GREEN}⏛${NC}"
ARROW="${SEA}▶${NC}"
BOOK="${RED}📖${NC}"
HOT="${ORANGE}🔥${NC}"
WARNING="${RED}⚠️${NC}"
RIGHT_ANGLE="${GREEN}∟${NC}"

