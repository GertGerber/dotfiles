#!/usr/bin/env bash
set -euo pipefail

# bin/dotfiles

DOTFILES_DIR="$HOME/.dotfiles"
REPO_URL="https://github.com/GertGerber/dotfiles.git"
BRANCH="main"

echo "[*] Checking base dependencies..."

# Git
if ! command -v git >/dev/null 2>&1; then
  echo "[*] Installing git..."
  sudo apt update && sudo apt install -y git
fi

# Python3
if ! command -v python3 >/dev/null 2>&1; then
  echo "[*] Installing python3..."
  sudo apt update && sudo apt install -y python3 python3-pip
fi

# Pip3
if ! command -v pip3 >/dev/null 2>&1; then
  echo "[*] Installing pip3..."
  sudo apt update && sudo apt install -y python3-pip
fi

# Ansible
if ! command -v ansible >/dev/null 2>&1; then
  echo "[*] Installing Ansible..."
  python3 -m pip install --user --upgrade ansible
  export PATH="$HOME/.local/bin:$PATH"
fi

# Clone or update repo
if [ -d "$DOTFILES_DIR" ]; then
  echo "[*] Updating dotfiles repository..."
  cd "$DOTFILES_DIR"
  git fetch --all
  git reset --hard "origin/$BRANCH"
else
  echo "[*] Cloning dotfiles repository..."
  git clone --branch "$BRANCH" "$REPO_URL" "$DOTFILES_DIR"
fi

# Run the bootstrap playbook
cd "$DOTFILES_DIR" || exit 1
ansible-playbook -i localhost, pre_tasks/bootstrap.yml --connection=local

# -------------------------------
# Add persistent alias "dotfiles"
# -------------------------------

SHELL_RC="$HOME/.bashrc"
# Detect zsh
if [ -n "${ZSH_VERSION-}" ]; then
  SHELL_RC="$HOME/.zshrc"
fi

ALIAS_CMD="alias dotfiles='$DOTFILES_DIR/bin/dotfiles'"

# Check if alias already exists
if grep -Fxq "$ALIAS_CMD" "$SHELL_RC"; then
  echo "[*] Alias 'dotfiles' already exists in $SHELL_RC, updating..."
  # Replace existing alias line
  sed -i "\|alias dotfiles=|c\\$ALIAS_CMD" "$SHELL_RC"
else
  echo "[*] Adding alias 'dotfiles' to $SHELL_RC"
  echo "$ALIAS_CMD" >> "$SHELL_RC"
fi

echo "[*] Alias 'dotfiles' is now available. Run 'source $SHELL_RC' or restart your shell."
