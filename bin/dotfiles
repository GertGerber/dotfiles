#!/usr/bin/env bash
set -euo pipefail

# -----------------------------
# Dotfiles Installer
# -----------------------------
DOTFILES_DIR="$HOME/.dotfiles"
DOTFILES_LOG="$HOME/.dotfiles.log"
IS_FIRST_RUN="$HOME/.dotfiles_run"
REPO_URL="https://github.com/GertGerber/dotfiles.git"
BRANCH="main"
CONFIG_FILE="$DOTFILES_DIR/group_vars/all.yml"

# -----------------------------
# Catppuccin Mocha Palette
# -----------------------------
# CAT_ROSEWATER="#f5e0dc"
CAT_ROSEWATER='\033[38;2;245;224;220m'
# CAT_FLAMINGO="#f2cdcd"
CAT_FLAMINGO='\033[38;2;242;205;205m'
# CAT_PINK="#f5c2e7"
CAT_PINK='\033[38;2;245;194;231m'
# CAT_MAUVE="#cba6f7"
CAT_MAUVE='\033[38;2;203;166;247m'
# CAT_RED="#f38ba8"
CAT_RED='\033[38;2;243;139;168m'
# CAT_MAROON="#eba0ac"
CAT_MAROON='\033[38;2;235;160;172m'
# CAT_PEACH="#fab387"
CAT_PEACH='\033[38;2;250;179;135m'
# CAT_YELLOW="#f9e2af"
CAT_YELLOW='\033[38;2;249;226;175m'
# CAT_GREEN="#a6e3a1"
CAT_GREEN='\033[38;2;166;227;161m'
# CAT_TEAL="#94e2d5"
CAT_TEAL='\033[38;2;148;226;213m'
# CAT_SKY="#89dceb"
CAT_SKY='\033[38;2;137;220;235m'
# CAT_SAPPHIRE="#74c7ec"
CAT_SAPPHIRE='\033[38;2;116;199;236m'
# CAT_BLUE="#89b4fa"
CAT_BLUE='\033[38;2;137;180;250m'
# CAT_LAVENDER="#b4befe"
CAT_LAVENDER='\033[38;2;180;190;254m'
# CAT_TEXT="#cdd6f4"
CAT_TEXT='\033[38;2;205;214;244m'
# CAT_SURFACE0="#a6adc8"
CAT_SURFACE0='\033[38;2;49;50;68m'
CAT_SUBTEXT1='\033[38;2;186;194;222m'
CAT_SUBTEXT0='\033[38;2;166;173;200m'
CAT_OVERLAY2='\033[38;2;147;153;178m'
CAT_OVERLAY1='\033[38;2;127;132;156m'
CAT_OVERLAY0='\033[38;2;108;112;134m'
CAT_SURFACE2='\033[38;2;88;91;112m'
CAT_SURFACE1='\033[38;2;69;71;90m'
CAT_BASE='\033[38;2;30;30;46m'
CAT_MANTLE='\033[38;2;24;24;37m'
CAT_CRUST='\033[38;2;17;17;27m'

RED="$CAT_RED"
GREEN="$CAT_GREEN"
YELLOW="$CAT_YELLOW"
BLUE="$CAT_BLUE"
ORANGE="$CAT_PEACH"
PURPLE="$CAT_MAUVE"
CYAN="$CAT_TEAL"
WHITE="$CAT_TEXT"
SEA="$CAT_SAPPHIRE"
NC="\e[0m"

# -----------------------------
# Emojis
# -----------------------------
CHECK_MARK="${GREEN}✔${NC}"
X_MARK="${RED}✖${NC}"
PIN="${RED}📌${NC}"
CLOCK="${GREEN}⏛${NC}"
ARROW="${SEA}▶${NC}"
BOOK="${RED}📖${NC}"
HOT="${ORANGE}🔥${NC}"
WARNING="${RED}⚠️${NC}"
RIGHT_ANGLE="${GREEN}∟${NC}"

# -----------------------------
# Print Fun Banner
# -----------------------------
print_banner() {
    echo ""
    echo -e "${SEA}  ██████╗ ███████╗██████╗ ████████╗     ██████╗ ███████╗██████╗ ██████╗ ███████╗██████╗ ${ORANGE} Dotfiles Installer ${NC}"
    echo -e "${SEA} ██╔════╝ ██╔════╝██╔══██╗╚══██╔══╝    ██╔════╝ ██╔════╝██╔══██╗██╔══██╗██╔════╝██╔══██╗${BLUE} by GertGerber ${NC}"
    echo -e "${SEA} ██║  ███╗█████╗  ██████╔╝   ██║       ██║  ███╗█████╗  ██████╔╝██████╔╝█████╗  ██████╔╝${PURPLE} Setup your dev environment ${NC}"
    echo -e "${SEA} ██║   ██║██╔══╝  ██╔══██╗   ██║       ██║   ██║██╔══╝  ██╔══██╗██╔══██╗██╔══╝  ██╔══██╗${YELLOW} Enjoy coding! 🚀${NC}"
    echo -e "${SEA} ╚██████╔╝███████╗██║  ██║   ██║       ╚██████╔╝███████╗██║  ██║██████╔╝███████╗██║  ██║${GREEN} Have fun with roles! 🎉${NC}"
    echo -e "${SEA}  ╚═════╝ ╚══════╝╚═╝  ╚═╝   ╚═╝        ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═════╝ ╚══════╝╚═╝  ╚═╝${NC}"
    echo ""
    echo -e "${CAT_BLUE}        ██████╗  ██████╗ ████████╗███████╗██╗██╗     ███████╗███████╗${NC}"
    echo -e "${CAT_BLUE}        ██╔══██╗██╔═══██╗╚══██╔══╝██╔════╝██║██║     ██╔════╝██╔════╝${NC}"
    echo -e "${CAT_BLUE}        ██║  ██║██║   ██║   ██║   █████╗  ██║██║     █████╗  ███████╗${NC}"
    echo -e "${CAT_BLUE}        ██║  ██║██║   ██║   ██║   ██╔══╝  ██║██║     ██╔══╝  ╚════██║${NC}"
    echo -e "${CAT_BLUE}        ██████╔╝╚██████╔╝   ██║   ██║     ██║███████╗███████╗███████║${NC}"
    echo -e "${CAT_BLUE}        ╚═════╝  ╚═════╝    ╚═╝   ╚═╝     ╚═╝╚══════╝╚══════╝╚══════╝${NC}"
    echo ""

    # Detect OS
    if grep -qEi "(Microsoft|WSL)" /proc/version &> /dev/null ; then
        echo -e "${CYAN}🌐 Detected OS: WSL${NC}"
    else
        echo -e "${CYAN}🌐 Detected OS: $(uname -s)${NC}"
    fi

    # Show enabled roles
    if [ -f "$CONFIG_FILE" ]; then
        echo -e "${BOOK} Enabled roles:"
        grep -E '^\s*-\s*\w+' "$CONFIG_FILE" | sed 's/^- /  ▶ /'
    fi
    echo ""
}

# -----------------------------
# Ensure base dependencies
# -----------------------------
install_dependencies() {
    echo -e "${ARROW} Checking dependencies..."

    sudo apt update -y

    # Git
    if ! command -v git >/dev/null 2>&1; then
        echo -e "${CLOCK} Installing git..."
        sudo apt install -y git
        hash -r   # refresh command lookup
    fi

    # Python3 + pip3
    if ! command -v python3 >/dev/null 2>&1; then
        echo -e "${CLOCK} Installing python3..."
        sudo apt install -y python3 python3-pip
        hash -r
    fi

    if ! command -v pip3 >/dev/null 2>&1; then
        echo -e "${CLOCK} Installing pip3..."
        sudo apt install -y python3-pip
        hash -r
    fi

    # Ansible
    if ! command -v ansible >/dev/null 2>&1; then
        echo -e "${CLOCK} Installing Ansible..."
        python3 -m pip install --user --upgrade ansible
        export PATH="$HOME/.local/bin:$PATH"
        hash -r
    fi

    # Final sanity check
    for cmd in git python3 pip3 ansible; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo -e "${X_MARK} ${cmd} still not found after install. Aborting."
            exit 1
        fi
    done

    echo -e "${CHECK_MARK} Dependencies installed."
}


# -----------------------------
# Clone or Update dotfiles repo safely
# -----------------------------
update_dotfiles() {
    mkdir -p "$DOTFILES_DIR"

    if [ -d "$DOTFILES_DIR/.git" ]; then
        echo -e "${ARROW} Updating dotfiles..."
        # Backup local all.yml
        if [ -f "$CONFIG_FILE" ]; then
            cp "$CONFIG_FILE" "$CONFIG_FILE.bak"
        fi
        cd "$DOTFILES_DIR"
        git fetch --all
        git reset --hard "origin/$BRANCH"
        # Restore all.yml
        if [ -f "$CONFIG_FILE.bak" ]; then
            mv "$CONFIG_FILE.bak" "$CONFIG_FILE"
        fi
        echo -e "${CHECK_MARK} Dotfiles updated."
    else
        echo -e "${ARROW} Cloning dotfiles repository..."
        git clone --branch "$BRANCH" "$REPO_URL" "$DOTFILES_DIR"
        echo -e "${CHECK_MARK} Dotfiles cloned."
    fi
}

# -----------------------------
# Ensure alias exists in both Bash and Zsh
# -----------------------------
setup_alias() {
    local shells=( "$HOME/.bashrc" "$HOME/.zshrc" )
    local alias_line="alias dotfiles='$DOTFILES_DIR/bin/dotfiles'"

    for shell_rc in "${shells[@]}"; do
        # Create the rc file if it doesn't exist
        if [ ! -f "$shell_rc" ]; then
            echo -e "${ARROW} $shell_rc not found, creating it..."
            touch "$shell_rc"
        fi

        # Add alias if not already present
        if ! grep -qF "$alias_line" "$shell_rc"; then
            echo -e "${ARROW} Adding 'dotfiles' alias to $shell_rc..."
            echo "$alias_line" >> "$shell_rc"
            echo -e "${CHECK_MARK} Alias added to $shell_rc!"
        else
            echo -e "${CHECK_MARK} Alias already exists in $shell_rc, skipping..."
        fi
    done

    echo -e "${CHECK_MARK} Done! Restart your shell or run 'source ~/.bashrc && source ~/.zshrc'"
}


# -------------------------------------------------------------------
# Ensure group_vars/all.yml exists
# -------------------------------------------------------------------
groupvars_check() {
    if [ ! -f "$DOTFILES_DIR/group_vars/all.yml" ]; then
        echo -e "${YELLOW}⚠️  group_vars/all.yml not found. Creating from example...${NC}"
        if [ -f "$DOTFILES_DIR/group_vars/all.yml.example" ]; then
            cp "$DOTFILES_DIR/group_vars/all.yml.example" "$DOTFILES_DIR/group_vars/all.yml"
            echo -e "${GREEN}✔ Created group_vars/all.yml. Please review and customize it.${NC}"
        else
            echo -e "${RED}✖ No all.yml.example found in $DOTFILES_DIR/group_vars. Cannot continue.${NC}"
            exit 1
        fi
    fi
}

# -----------------------------
# Display first-run instructions
# -----------------------------
first_run_message() {
    if [ ! -f "$IS_FIRST_RUN" ]; then
        echo ""
        echo -e "${CHECK_MARK} ${CAT_GREEN}🎉 Dotfiles installation complete!${NC}"
        echo ""
        echo -e "${ARROW} ${CAT_TEAL}Next steps:${NC}"
        echo -e "   1. Customize your setup: ${CAT_LAVENDER}nvim $CONFIG_FILE${NC}"
        echo -e "   2. Apply changes anytime: ${CAT_LAVENDER}dotfiles${NC}"
        echo -e "   3. Get help: ${CAT_LAVENDER}https://discord.gg/5M4hjfyRBj${NC}"
        echo ""
        echo -e "${ARROW} ${CAT_TEAL}Please reboot your computer to complete the setup.${NC}"
        echo ""
        touch "$IS_FIRST_RUN"
    fi
}

# -----------------------------
# Run Bootstrap Playbook
# -----------------------------
run_bootstrap() {
    cd "$DOTFILES_DIR" || exit 1
    # First, run bootstrap (ensures base packages + sudo check)
    ansible-playbook -i localhost, pre_tasks/bootstrap.yml --connection=local
    
    # Then, run the main playbook (applies roles from group_vars/all.yml)
    ansible-playbook -i localhost, main.yml --connection=local
}


# -----------------------------
# Main Execution
# -----------------------------
main() {
    print_banner
    install_dependencies
    update_dotfiles
    groupvars_check
    setup_alias
    run_bootstrap
    first_run_message
    echo -e "${GREEN}🎉 Dotfiles setup complete! Run 'dotfiles' to re-run.${NC}"
}

main "$@"
