# -----------------------------
# Dotfiles Installer
# -----------------------------
DOTFILES_DIR="$HOME/.dotfiles"
REPO_URL="https://github.com/GertGerber/dotfiles.git"
BRANCH="main"
CONFIG_FILE="$DOTFILES_DIR/group_vars/all.yml"

# -----------------------------
