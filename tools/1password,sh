#!/bin/bash

op item list --vault "Personal"

# Set the item ID or title
ITEM_ID="wzkl7wsddq4lp6tkz6cqbmbo7q"  # Replace with your item ID

# Fetch item details in JSON and pretty-print
op item get "$ITEM_ID" --format json | jq '. | {title: .title, vault: .vault.name, fields: [.fields[] | {label: .label, value: .value}]}'
